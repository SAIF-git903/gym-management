# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/gym-management

# JWT (required for API + login)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# One-time gym owner (npm run create-owner)
# OWNER_NAME=Gym Owner
# OWNER_EMAIL=owner@example.com
# OWNER_PASSWORD=change-me-min-6-chars
